{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "assignees": [
    "kapsner",
    "hann-sch",
    "ajugeorge97"
  ],
  "extends": [
    ":preserveSemverRanges",
    "group:all",
    "config:recommended"
  ],
  "groupName": "all dependencies",
  "separateMajorMinor": true,
  "groupSlug": "all",
  "packageRules": [
    {
      "groupName": "all dependencies",
      "groupSlug": "all",
      "matchPackageNames": [
        "*"
      ]
    },
    {
      "matchFileNames": [
        "src/commit_hooks/templates/configs/**",
        "pyproject.toml"
      ]
    }
  ],
  "pre-commit": {
    "enabled": true,
    "managerFilePatterns": [
      "/^src/.*pre-commit-cfg\\.yaml$/"
    ]
  },
  "lockFileMaintenance": {
    "enabled": true
  }
}

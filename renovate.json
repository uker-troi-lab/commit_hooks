{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "assignees": [
    "kapsnelz",
    "kapsner",
    "schreihs",
    "hann-sch",
    "georgeau",
    "ajugeorge97"
  ],
  "extends": [
    ":preserveSemverRanges",
    "group:all",
    "config:recommended"
  ],
  "groupName": "all dependencies",
  "separateMajorMinor": true,
  "groupSlug": "all",
  "packageRules": [
    {
      "groupName": "all dependencies",
      "groupSlug": "all",
      "matchPackageNames": [
        "*"
      ],
      "pre-commit": {
        "managerFilePatterns": ["/^.*pre-commit.*\\.yaml$/"]
      }
    }
  ]
}

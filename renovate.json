{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "assignees": [
    "kapsner",
    "hann-sch",
    "ajugeorge97"
  ],
  "extends": [
    ":preserveSemverRanges",
    "group:all",
    "config:recommended"
  ],
  "groupName": "all dependencies",
  "separateMajorMinor": true,
  "groupSlug": "all",
  "packageRules": [
    {
      "groupName": "all dependencies",
      "groupSlug": "all",
      "matchPackageNames": [
        "*"
      ]
    },
    {
      "matchFileNames": [
        "pyproject.toml", "pre-commit-cfg.yaml"
      ]
    }
  ],
  "pre-commit": {
    "enabled": true,
    "managerFilePatterns": [
      "/^src/.*pre-commit-cfg\\.yaml$/"
    ],
    "ignorePaths": ["**/.pre-commit-config.yaml"]
  },
  "lockFileMaintenance": {
    "enabled": true,
    "extends": [
      "schedule:weekly"
    ]
  },
  "minor": {
    "automerge": true
  },
  "patch": {
    "automerge": true
  },
  "pin": {
    "automerge": true
  },
  "dependencyDashboard": true,
  "rebaseWhen": "behind-base-branch"
}

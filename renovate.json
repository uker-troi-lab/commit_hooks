{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "assignees": [
    "kapsnelz",
    "kapsner",
    "schreihs",
    "hann-sch",
    "georgeau",
    "ajugeorge97"
  ],
  "extends": [
    ":preserveSemverRanges",
    "group:all",
    "config:recommended"
  ],
  "groupName": "all dependencies",
  "separateMajorMinor": true,
  "groupSlug": "all",
  "packageRules": [
    {
      "groupName": "all dependencies",
      "groupSlug": "all",
      "matchPackageNames": [
        "*"
      ]
    },
    {
      "matchFileNames": [
        "src/commit_hooks/templates/configs/**",
        "pyproject.toml"
      ],
      "bumpVersions": [
        {
          "name": "Bump version on config template update",
          "filePatterns": ["pyproject.toml"],
          "matchStrings": ["version\\s*=\\s*\"(?<version>[^\\s\"]+)\""],
          "bumpType": "patch",
          "generate_tag": true,
          "tag_prefix": ""
        }
      ]
    }
  ],
  "pre-commit": {
    "enabled": true,
    "managerFilePatterns": ["/^.*pre-commit.*\\.yaml$/"]
  },
  "lockFileMaintenance": {
    "enabled": true
  }
}
